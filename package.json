{
  "name": "chrome-ai-extension-sidepanel-llm2",
  "version": "1.0.0",
  "description": "Chrome side panel chat extension with OpenAI and browser context capture.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opvelll/chrome_ai_extension_SidepanelLLM2.git"
  },
  "homepage": "https://github.com/opvelll/chrome_ai_extension_SidepanelLLM2",
  "bugs": {
    "url": "https://github.com/opvelll/chrome_ai_extension_SidepanelLLM2/issues"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test:unit": "pnpm test:unit:logic && pnpm test:unit:integration && pnpm test:unit:ui",
    "test:unit:logic": "vitest run --config vitest.unit.config.ts",
    "test:unit:integration": "vitest run --config vitest.integration.config.ts",
    "test:unit:ui": "vitest run --config vitest.ui.config.ts",
    "test:e2e": "pnpm build && playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "lucide-react": "^0.577.0",
    "openai": "^6.27.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.1.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.1.28",
    "@types/node": "^25.4.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "jsdom": "^27.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^4.0.18"
  }
}
